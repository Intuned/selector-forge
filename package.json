{
  "name": "selector-extension",
  "description": "Intuned Selector — pick an element on a page, get a reliable selector.",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:e2e": "wxt build --mode e2e",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "wxt build --mode e2e && playwright test",
    "icons": "node scripts/gen-icons.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitest/browser": "^3.2.0",
    "@webext-core/fake-browser": "^1.5.1",
    "@wxt-dev/module-react": "^1.2.2",
    "happy-dom": "^15.0.0",
    "playwright": "^1.49.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.0",
    "wxt": "^0.20.0"
  },
  "dependencies": {
    "@apollo/client": "^4.1.0",
    "@webext-core/messaging": "^3.0.2",
    "lucide-react": "0.539.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "graphql": "^16.12.0",
    "rxjs": "^7.3.0",
    "zod": "^3.23.8"
  }
}
